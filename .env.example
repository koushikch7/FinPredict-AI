# ─── Application ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=info

# ─── Security ───────────────────────────────────────────────────
# REQUIRED. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
COOKIE_SECRET=change_me_to_another_long_random_string

# ─── AI (system default) ────────────────────────────────────────
# Recommended: Arbiter — OpenAI-compatible smart router/gateway aggregating
# 12+ free providers (Gemini, Groq, Cerebras, Cloudflare Workers AI,
# OpenRouter, Cohere, HuggingFace, …) with automatic fallback when any one
# provider hits its rate limit.  See https://arbiter.chkoushik.com/docs
DEFAULT_AI_PROVIDER=Arbiter
DEFAULT_AI_MODEL=auto

ARBITER_API_KEY=
ARBITER_BASE_URL=https://arbiter.chkoushik.com/v1
ARBITER_MODEL=auto

# Direct Gemini key — used as the primary if DEFAULT_AI_PROVIDER=Gemini and
# as the active fallback target.  Free tier is capped at ~5 RPM/model.
GEMINI_API_KEY=

# Cross-provider fallback: if the active provider returns 429/quota-exhausted,
# automatically retry the request via Arbiter.  Set to false to disable.
AI_FALLBACK_ENABLED=true

# Optional: OpenAI-compatible endpoint as global default
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ─── Database ───────────────────────────────────────────────────
DB_PATH=./data/finance.db

# ─── Optional: News provider ────────────────────────────────────
NEWS_API_KEY=

# ─── Optional: Default Kite (Zerodha) ──────────────────────────
# Each user enters their own credentials in the Brokers page;
# these env vars are only used if you want a system-wide default.
KITE_API_KEY=
KITE_API_SECRET=

# ─── Bootstrap ──────────────────────────────────────────────────
# If true, the very first /api/auth/register call may create an Admin.
ALLOW_FIRST_ADMIN_REGISTRATION=true

# ─── Playground (paper-trading) ────────────────────────────────
# Cron expression for the AI auto-trader (only fires during NSE hours)
PLAYGROUND_CRON=*/15 * * * 1-5
